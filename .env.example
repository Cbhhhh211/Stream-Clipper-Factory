# ------------------------------
# Bilibili auth (optional)
# ------------------------------
# Required for members-only / login-gated content.
BILI_SESSDATA=
BILI_BILI_JCT=
BILI_BUVID3=
BILI_COOKIES_FILE=
# Recommended for desktop use after logging in to bilibili in your browser:
# YTDLP_COOKIES_FROM_BROWSER=edge
# YTDLP_COOKIES_FROM_BROWSER=chrome
YTDLP_COOKIES_FROM_BROWSER=
YTDLP_AUTO_COOKIES_FROM_BROWSER=1
YTDLP_MIN_VERSION=2025.01.15

# ------------------------------
# Core pipeline
# ------------------------------
WHISPER_MODEL=tiny
ASR_BEAM_SIZE=1
ASR_VAD_MIN_SILENCE_MS=1000
OUTPUT_DIR=./output
TOP_N=10
ENABLE_FEEDBACK_RANKING=1
# FEEDBACK_RANKER_PATH=./output/_api_jobs/_feedback/ranker_model.json
ENABLE_LLM_RERANK=0
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_MAX_CANDIDATES=20
LLM_SCORE_WEIGHT=0.65
LLM_TIMEOUT_SEC=30
ENABLE_SEMANTIC_ENRICHMENT=0
SEMANTIC_MODEL=
SEMANTIC_MAX_CANDIDATES=8
SEMANTIC_SCORE_WEIGHT=0.2
SEMANTIC_TIMEOUT_SEC=30
ENABLE_BOUNDARY_ADAPTATION=1
# BOUNDARY_PROFILE_PATH=./output/_api_jobs/_feedback/boundary_profile.json
# ADJUSTMENT_LOG_PATH=./output/_api_jobs/_feedback/clip_adjustments.jsonl
ADAPTIVE_PADDING=1
HALF_PEAK_RATIO=0.5

# ------------------------------
# API mode
# ------------------------------
# lite: local single-node mode (no redis/postgres required)
# full: full SaaS mode (requires redis/postgres/minio)
# auto: try full then fallback to lite
API_MODE=lite

# ------------------------------
# API security / web
# ------------------------------
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
API_RATE_LIMIT_RPM=180
PUBLIC_LEADS_PATH=./output/_public/leads.jsonl

# Lite mode local queue concurrency
LITE_MAX_CONCURRENT_JOBS=1
LITE_MAX_UPLOAD_MB=4096
# Optional: restrict user-selected output_dir under a trusted base folder
# LITE_OUTPUT_BASE_DIR=D:\\clips

# ------------------------------
# Worker reliability
# ------------------------------
WORKER_CMD_TIMEOUT_SEC=1200
WORKER_YTDLP_TIMEOUT_SEC=900
WORKER_FFMPEG_TIMEOUT_SEC=900
WORKER_FFPROBE_TIMEOUT_SEC=30
WORKER_CMD_RETRIES=2
CLIP_FFMPEG_PRESET=ultrafast
CLIP_FFMPEG_CRF=23
CLIP_FFMPEG_AUDIO_BITRATE=160k
CLIP_FFMPEG_WORKERS=4

# Inference client retry
INFERENCE_TIMEOUT_SEC=600
INFERENCE_RETRIES=2

# ------------------------------
# Full-stack services (docker-compose)
# ------------------------------
DATABASE_URL=postgresql://clipper:clipper@localhost:5432/stream_clipper
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=stream-clipper
S3_REGION=us-east-1
JWT_SECRET=change-me-in-production-use-a-real-secret
INFERENCE_URL=http://localhost:8001

# ------------------------------
# Public site / monetization
# ------------------------------
# Runtime site config served by the API.
# Example:
# PUBLIC_SITE_BRAND=流剪工坊
# PUBLIC_CONTACT_EMAIL=founder@yourdomain.com
# PUBLIC_BOOKING_URL=https://cal.com/yourname/demo
# PUBLIC_DOWNLOAD_URL=https://yourdomain.com/downloads/stream-clipper.zip
# PUBLIC_DEMO_URL=https://yourdomain.com/studio
# PUBLIC_PRICE_CREATOR_URL=https://pay.example.com/creator
# PUBLIC_PRICE_STUDIO_URL=https://pay.example.com/studio
# PUBLIC_PRICE_TEAM_URL=https://cal.com/yourname/enterprise
# PUBLIC_PRICE_CREATOR_BULLETS=本地导入与自动切片|剪辑复核与批量导出|适合每天 1-2 场直播

# Public checkout / digital delivery
# Use Stripe Checkout for payment and a protected S3/R2 object for delivery.
PUBLIC_ORDERS_PATH=./output/_public/orders
PUBLIC_DOWNLOAD_LINK_TTL_SEC=900

# Stripe (server-side)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_CREATOR=
STRIPE_PRICE_ID_STUDIO=

# Public products
PUBLIC_PRODUCT_CREATOR_NAME=流剪工坊 创作者版
PUBLIC_PRODUCT_CREATOR_PRICE=CNY 9.9
PUBLIC_PRODUCT_CREATOR_DESCRIPTION=适合个人主播和兼职剪辑，先跑通直播回放到短视频的基础工作流。
PUBLIC_PRODUCT_CREATOR_S3_KEY=
PUBLIC_PRODUCT_CREATOR_DOWNLOAD_URL=

PUBLIC_PRODUCT_STUDIO_NAME=流剪工坊 工作室版
PUBLIC_PRODUCT_STUDIO_PRICE=CNY 29.9
PUBLIC_PRODUCT_STUDIO_DESCRIPTION=适合小团队和工作室，强调更稳定的交付效率与更清晰的售后支持。
PUBLIC_PRODUCT_STUDIO_S3_KEY=
PUBLIC_PRODUCT_STUDIO_DOWNLOAD_URL=
